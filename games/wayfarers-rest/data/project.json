  "scenes": {
    "scene.demo.intro": {
      "commands": [
        {
          "cmd": "show",
          "who": "maren",
          "expr": "wary",
          "at": "center"
        },
        {
          "cmd": "say",
          "who": "Maren",
          "text": "You're new. Don't expect me to carry your bags."
        },
        {
          "cmd": "say",
          "who": "Maren",
          "text": "...That came out harsher than I meant. Old habit."
        },
        {
          "cmd": "choice",
          "options": [
            {
              "text": "“No harm done.”",
              "then": [
                {
                  "cmd": "jump",
                  "scene": "scene.demo.branch_kind"
                }
              ]
            },
            {
              "text": "“Noted. Keep your distance, then.”",
              "then": [
                {
                  "cmd": "jump",
                  "scene": "scene.demo.branch_curt"
                }
              ]
            }
          ]
        }
      ]
    },
